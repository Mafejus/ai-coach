# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_coach"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# NEXTAUTH / AUTH.JS
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
# Railway production — required by Auth.js v5:
AUTH_SECRET="your-secret-here-same-as-nextauth-secret"
AUTH_TRUST_HOST="true"

# ============================================
# GOOGLE OAUTH (Calendar + Auth)
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# GOOGLE AI (Gemini)
# ============================================
GOOGLE_AI_API_KEY="your-gemini-api-key"

# ============================================
# STRAVA
# ============================================
STRAVA_CLIENT_ID="your-strava-client-id"
STRAVA_CLIENT_SECRET="your-strava-client-secret"
STRAVA_WEBHOOK_VERIFY_TOKEN="your-strava-webhook-verify-token"

# ============================================
# GARMIN (credentials, encrypted in DB)
# ============================================
ENCRYPTION_KEY="your-32-byte-aes-key-base64-encoded"

# ============================================
# WEB PUSH
# ============================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:your@email.com"

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
